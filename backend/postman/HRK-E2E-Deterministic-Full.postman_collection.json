              "const jsonData = pm.response.json();",
              "const targetName = `E2E-Company-${pm.collectionVariables.get('testRunId')}`;",
              "const found = jsonData.items.find(c => c.name === targetName);",
              "if (found) {",
              "  pm.collectionVariables.set('companyId', found.id);",
              "  pm.execution.setNextRequest('04 - Create Customer');",
              "} else {",
              "  pm.execution.setNextRequest('03 - Create Company');",
              "}"
            ]
          }
        }
