# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=HRK Backend
APP_VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=true

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Used by docker-compose to create the database
POSTGRES_USER=hrk
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=hrk_db

# Full async SQLAlchemy DSN (used by the app and alembic)
# docker-compose: host=db (service name)  |  local dev without Docker: host=localhost
DATABASE_URL=postgresql+asyncpg://hrk:CHANGEME@db:5432/hrk_db

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# When running via docker-compose the endpoint is http://minio:9000 (internal).
# For local development without docker set it to http://localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=hrk-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_SSE_ENABLED=true
S3_SSE_ALGORITHM=AES256
S3_REQUIRE_PRIVATE_BUCKET=true
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
DOCUMENT_PRESIGNED_URL_TTL_SECONDS=300

# ── Docker ────────────────────────────────────────────────────────────────────
PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim

# ── Server / CORS ─────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
FE_DOMAIN=http://localhost:4173
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# ── Ollama (embeddings, local Docker service) ─────────────────────────────────
# docker-compose: http://ollama:11434  |  local dev: http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenRouter (AI mode — Gemma 4 via API) ────────────────────────────────────
# Get key at https://openrouter.ai/keys
# To switch to local ollama: set BASE_URL=http://localhost:11434/v1 and KEY=ollama
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ── AD integration for main API ──────────────────────────────────────────────
AD_SERVICE_URL=http://localhost:8001
API_AD_DOMAIN=HRK

# ── AD Microservice (Active Directory) ──────────────────────────────────────
AD_APP_NAME=HRK AD Service
AD_APP_VERSION=0.1.0
AD_DEBUG=false
AD_SERVER_URL=ldap://localhost:389
AD_DOMAIN=hrk.local
AD_BASE_DN=DC=hrk,DC=local
AD_USE_SSL=false
AD_MOCK_MODE=true
AD_SIMULATED_IDENTITY=HRK\asia

# GUS
GUS_CPI_VARIABLE_ID=ID
GUS_CLIENT_ID=ID