# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=HRK Backend
APP_VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=false

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Used by docker-compose to create the database
POSTGRES_USER=hrk
POSTGRES_PASSWORD=hrk_secret
POSTGRES_DB=hrk_db

# Full async SQLAlchemy DSN (used by the app and alembic)
DATABASE_URL=postgresql+asyncpg://hrk:hrk_secret@localhost:5432/hrk_db

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# When running via docker-compose the endpoint is http://minio:9000 (internal).
# For local development without docker set it to http://localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=hrk-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── Server / CORS ─────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
FE_DOMAIN=http://localhost:4173
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
