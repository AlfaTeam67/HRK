# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=HRK Backend
APP_VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=true

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Used by docker-compose to create the database
POSTGRES_USER=hrk
POSTGRES_PASSWORD=hrk_secret
POSTGRES_DB=hrk_db

# Full async SQLAlchemy DSN (used by the app and alembic)
DATABASE_URL=postgresql+asyncpg://hrk:hrk_secret@localhost:5432/hrk_db

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# When running via docker-compose the endpoint is http://minio:9000 (internal).
# For local development without docker set it to http://localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=hrk-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── Server / CORS ─────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
FE_DOMAIN=http://localhost:4173
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# ── AD integration for main API ──────────────────────────────────────────────
AD_SERVICE_URL=http://localhost:8001
API_AD_DOMAIN=HRK

# ── AD Microservice (Active Directory) ──────────────────────────────────────
AD_APP_NAME=HRK AD Service
AD_APP_VERSION=0.1.0
AD_DEBUG=false
AD_SERVER_URL=ldap://localhost:389
AD_DOMAIN=hrk.local
AD_BASE_DN=DC=hrk,DC=local
AD_USE_SSL=false
AD_MOCK_MODE=true
AD_SIMULATED_IDENTITY=HRK\asia
